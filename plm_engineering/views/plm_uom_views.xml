<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_plm_product_uom_list" model="ir.ui.view">
        <field name="name">plm.product.uom.list</field>
        <field name="model">plm.product.uom</field>
        <field name="arch" type="xml">
            <list string="Product UoM" editable="bottom">
                <field name="sequence"/>
                <field name="name"/>
                <field name="code"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_plm_product_uom_form" model="ir.ui.view">
        <field name="name">plm.product.uom.form</field>
        <field name="model">plm.product.uom</field>
        <field name="arch" type="xml">
            <form string="Product UoM">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="sequence"/>
                        <field name="active" widget="boolean_toggle"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_plm_product_uom" model="ir.actions.act_window">
        <field name="name">Product UoM</field>
        <field name="res_model">plm.product.uom</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>