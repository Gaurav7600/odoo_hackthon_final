<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_plm_eco_comparison_wizard_form" model="ir.ui.view">
        <field name="name">plm.eco.comparison.wizard.form</field>
        <field name="model">plm.eco.comparison.wizard</field>
        <field name="arch" type="xml">
            <form string="Versioned Change Comparison" class="o_form_readonly">

                <!-- Invisible field bindings -->
                <field name="eco_id" invisible="1"/>
                <field name="eco_type" invisible="1"/>
                <field name="eco_name" invisible="1"/>
                <field name="current_version" invisible="1"/>
                <field name="new_version_label" invisible="1"/>

                <sheet>
                    <group col="3" string="Comparison Info">
                        <field name="eco_name" readonly="1" string="ECO"/>
                        <field name="current_version" readonly="1"/>
                        <field name="new_version_label" readonly="1"/>
                    </group>

                    <!-- The comparison HTML output -->
                    <div class="o_field_widget">
                        <field name="comparison_html"
                                widget="html"
                                readonly="1"
                                nolabel="1"/>
                    </div>

                </sheet>

                <footer>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>

            </form>
        </field>
    </record>

</odoo>
