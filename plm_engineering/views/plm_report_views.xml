<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════
         ECO SUMMARY REPORT — Read-Only List
    ══════════════════════════════════════════════ -->
    <record id="view_plm_eco_report_list" model="ir.ui.view">
        <field name="name">plm.eco.report.list</field>
        <field name="model">plm.eco</field>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <list string="ECO Report"
                  create="false" delete="false"
                  decoration-success="state == 'done'"
                  decoration-warning="state == 'in_review'"
                  decoration-info="state == 'approved'"
                  decoration-muted="state == 'draft'">
                <field name="reference" string="ECO Ref"/>
                <field name="name" string="Title"/>
                <field name="eco_type" widget="badge"
                       decoration-info="eco_type == 'product'"
                       decoration-warning="eco_type == 'bom'"/>
                <field name="product_id" string="Product"/>
                <field name="bom_id" string="BoM" optional="show"/>
                <field name="current_version" string="Version"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="effective_date"/>
                <field name="applied_date" string="Applied On" optional="show"/>
                <field name="stage_id"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'done'"
                       decoration-warning="state == 'in_review'"
                       decoration-info="state == 'approved'"
                       decoration-muted="state == 'draft'"/>
                <field name="change_count" string="# Changes"/>
                <button name="action_view_comparison" type="object"
                        string="📊 View Changes"
                        class="btn-sm btn-outline-primary"
                        invisible="change_count == 0"/>
            </list>
        </field>
    </record>

    <!-- ECO Report Search View -->
    <record id="view_plm_eco_report_search" model="ir.ui.view">
        <field name="name">plm.eco.report.search</field>
        <field name="model">plm.eco</field>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <search string="ECO Report Filters">
                <field name="name" string="Title"/>
                <field name="reference"/>
                <field name="product_id"/>
                <field name="user_id"/>
                <filter string="Product ECOs" name="product_type"
                        domain="[('eco_type', '=', 'product')]"/>
                <filter string="BoM ECOs" name="bom_type"
                        domain="[('eco_type', '=', 'bom')]"/>
                <separator/>
                <filter string="Done / Applied" name="done"
                        domain="[('state', '=', 'done')]"/>
                <filter string="In Review" name="review"
                        domain="[('state', '=', 'in_review')]"/>
                <separator/>
                <group expand="1" string="Group By">
                    <filter string="ECO Type" name="grp_type"
                            context="{'group_by': 'eco_type'}"/>
                    <filter string="Product" name="grp_product"
                            context="{'group_by': 'product_id'}"/>
                    <filter string="Stage" name="grp_stage"
                            context="{'group_by': 'stage_id'}"/>
                    <filter string="Month" name="grp_month"
                            context="{'group_by': 'effective_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Pivot Report -->
    <record id="view_plm_eco_pivot" model="ir.ui.view">
        <field name="name">plm.eco.pivot</field>
        <field name="model">plm.eco</field>
        <field name="arch" type="xml">
            <pivot string="ECO Analysis" disable_linking="0">
                <field name="eco_type" type="row"/>
                <field name="stage_id" type="col"/>
                <field name="change_count" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Bar Graph -->
    <record id="view_plm_eco_graph" model="ir.ui.view">
        <field name="name">plm.eco.graph</field>
        <field name="model">plm.eco</field>
        <field name="arch" type="xml">
            <graph string="ECO Analysis" type="bar">
                <field name="eco_type" type="row"/>
                <field name="state" type="col"/>
            </graph>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════
         PRODUCT VERSION HISTORY LIST
    ══════════════════════════════════════════════ -->
    <record id="view_plm_product_version_list" model="ir.ui.view">
        <field name="name">plm.product.version.list</field>
        <field name="model">plm.product</field>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <list string="Product Version History"
                  create="false" delete="false"
                  decoration-muted="status == 'archived'"
                  decoration-success="status == 'active'">
                <field name="name" string="Product Name"/>
                <field name="version" string="Version"/>
                <field name="version_number" string="Ver #" optional="show"/>
                <field name="sale_price" string="Sale Price" widget="monetary"
                       options="{'currency_field': 'currency_id'}"/>
                <field name="cost_price" string="Cost Price" widget="monetary"
                       options="{'currency_field': 'currency_id'}"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'active'"
                       decoration-danger="status == 'archived'"/>
                <field name="parent_product_id" string="Previous Version" optional="show"/>
                <field name="created_by_eco_id" string="Created By ECO" optional="show"/>
                <field name="currency_id" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════
         ACTIONS
    ══════════════════════════════════════════════ -->

    <record id="action_plm_eco_report" model="ir.actions.act_window">
        <field name="name">ECO Report</field>
        <field name="res_model">plm.eco</field>
        <field name="view_mode">list,pivot,graph,form</field>
        <field name="views" eval="[
            (ref('view_plm_eco_report_list'), 'list'),
            (ref('view_plm_eco_pivot'), 'pivot'),
            (ref('view_plm_eco_graph'), 'graph'),
            (False, 'form'),
        ]"/>
        <field name="search_view_id" ref="view_plm_eco_report_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No ECOs to report yet.</p>
            <p>
                The ECO Report shows all change orders.
                Click <b>View Changes</b> on any row to open the diff comparison view.
            </p>
        </field>
    </record>

    <record id="action_plm_product_version_history" model="ir.actions.act_window">
        <field name="name">Product Version History</field>
        <field name="res_model">plm.product</field>
        <field name="view_mode">list,form</field>
        <field name="views" eval="[
            (ref('view_plm_product_version_list'), 'list'),
            (False, 'form'),
        ]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No product version history yet.</p>
            <p>Products modified through ECO workflows appear here with full version lineage.</p>
        </field>
    </record>

    <record id="action_plm_bom_change_history" model="ir.actions.act_window">
        <field name="name">BoM Change History</field>
        <field name="res_model">plm.bom</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('created_by_eco_id', '!=', False)]</field>
        <field name="search_view_id" ref="view_plm_bom_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No BoM ECO history yet.</p>
        </field>
    </record>

    <record id="action_plm_active_product_bom_matrix" model="ir.actions.act_window">
        <field name="name">Active Product–BoM Matrix</field>
        <field name="res_model">plm.bom</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('status', '=', 'active')]</field>
        <field name="context">{'search_default_grp_product': 1}</field>
        <field name="search_view_id" ref="view_plm_bom_search"/>
    </record>

</odoo>
