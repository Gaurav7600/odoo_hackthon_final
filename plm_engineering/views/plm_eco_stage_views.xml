<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_plm_eco_stage_list" model="ir.ui.view">
        <field name="name">plm.eco.stage.list</field>
        <field name="model">plm.eco.stage</field>
        <field name="arch" type="xml">
            <list string="ECO Stages" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="is_start_stage" string="Start Stage"/>
                <field name="is_approval_required" string="Approval Required"/>
                <field name="is_final_stage" string="Final Stage"/>
                <field name="is_cancel_stage" string="Cancel Stage"/>
                <field name="fold" string="Folded"/>
                <field name="eco_count" string="ECOs" readonly="1"/>
            </list>
        </field>
    </record>

    <record id="view_plm_eco_stage_form" model="ir.ui.view">
        <field name="name">plm.eco.stage.form</field>
        <field name="model">plm.eco.stage</field>
        <field name="arch" type="xml">
            <form string="ECO Stage">"
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Stage Name..."/></h1>
                    </div>
                    <group>
                        <group string="Order &amp; Display">
                            <field name="sequence"/>
                            <field name="color" widget="color_picker"/>
                            <field name="fold"/>
                        </group>
                        <group string="Stage Rules">
                            <field name="is_start_stage"
                                    help="New ECOs are placed here by default."/>
                            <field name="is_approval_required"
                                    help="If checked: Approve/Reject buttons shown. If unchecked: Validate button shown."/>
                            <field name="is_final_stage"
                                    help="ECOs entering this stage are applied. Old version archived, new version activated."/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1" colspan="2"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_plm_eco_stage" model="ir.actions.act_window">
        <field name="name">ECO Stages</field>
        <field name="res_model">plm.eco.stage</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No stages configured!</p>
            <p>Create ECO stages: mark one as <b>Start Stage</b> and one as <b>Final Stage</b>.</p>
        </field>
    </record>

</odoo>
