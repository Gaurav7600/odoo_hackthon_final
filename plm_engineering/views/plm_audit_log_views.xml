<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_plm_eco_approval_list" model="ir.ui.view">
        <field name="name">plm.eco.approval.list</field>
        <field name="model">plm.eco.approval</field>
        <field name="arch" type="xml">
            <list string="ECO Approvals" default_order="create_date desc">
                <field name="eco_id" string="ECO"/>
                <field name="eco_reference" string="Reference" optional="show"/>
                <field name="requested_by_id" string="Requested By" widget="many2one_avatar_user"/>
                <field name="reviewed_by_id" string="Reviewed By" widget="many2one_avatar_user" optional="show"/>
                <field name="stage_id" string="Stage" optional="show"/>
                <field name="state" widget="badge"/>
                <field name="review_date" optional="show"/>
                <field name="note" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_plm_audit_log_list" model="ir.ui.view">
        <field name="name">plm.audit.log.list</field>
        <field name="model">plm.audit.log</field>
        <field name="arch" type="xml">
            <list string="PLM Audit Trail"
                  create="false" delete="false" edit="false"
                  default_order="timestamp desc">
                <field name="timestamp" string="Date &amp; Time"/>
                <field name="eco_id" string="ECO"/>
                <field name="eco_reference" string="Reference" optional="show"/>
                <field name="user_id" widget="many2one_avatar_user" string="User"/>
                <field name="action" string="Action"/>
                <field name="model_name" string="Model" optional="show"/>
                <field name="record_name" string="Record / Field"/>
                <field name="change_summary" string="Change (Before → After)"/>
            </list>
        </field>
    </record>

    <record id="view_plm_audit_log_form" model="ir.ui.view">
        <field name="name">plm.audit.log.form</field>
        <field name="model">plm.audit.log</field>
        <field name="arch" type="xml">
            <form string="Audit Log Entry" create="false" edit="false" delete="false">
                <sheet>
                    <div class="alert alert-warning" role="alert">
                        <i class="fa fa-lock"/> &amp;nbsp;
                        <strong>Immutable Record:</strong>
                        Audit log entries cannot be edited or deleted. They ensure full PLM traceability.
                    </div>
                    <group>
                        <group string="Event Info">
                            <field name="action" readonly="1"/>
                            <field name="eco_id" readonly="1"/>
                            <field name="eco_reference" readonly="1"/>
                            <field name="timestamp" readonly="1"/>
                            <field name="user_id" readonly="1" widget="many2one_avatar_user"/>
                        </group>
                        <group string="Change Details">
                            <field name="model_name" readonly="1"/>
                            <field name="record_name" readonly="1"/>
                            <field name="old_value" readonly="1"/>
                            <field name="new_value" readonly="1"/>
                            <field name="change_summary" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_plm_audit_log_search" model="ir.ui.view">
        <field name="name">plm.audit.log.search</field>
        <field name="model">plm.audit.log</field>
        <field name="arch" type="xml">
            <search string="Search Audit Logs">
                <field name="action"/>
                <field name="record_name"/>
                <field name="user_id"/>
                <field name="eco_id"/>
                <filter string="This Week" name="this_week"
                        domain="[('timestamp', '&gt;=', (context_today() - relativedelta(weeks=1)).strftime('%Y-%m-%d'))]"/>
                <filter string="Today" name="today"
                        domain="[('timestamp', '&gt;=', context_today().strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Group By">
                    <filter string="ECO" name="grp_eco" context="{'group_by': 'eco_id'}"/>
                    <filter string="User" name="grp_user" context="{'group_by': 'user_id'}"/>
                    <filter string="Action" name="grp_action" context="{'group_by': 'action'}"/>
                    <filter string="Date" name="grp_date" context="{'group_by': 'timestamp:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_plm_audit_log" model="ir.actions.act_window">
        <field name="name">PLM Audit Trail</field>
        <field name="res_model">plm.audit.log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_plm_audit_log_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No audit events yet.</p>
            <p>Every critical PLM action is automatically logged here for full traceability.</p>
        </field>
    </record>

</odoo>
