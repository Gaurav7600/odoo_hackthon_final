<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="seq_plm_eco" model="ir.sequence">
            <field name="name">PLM Engineering Change Order</field>
            <field name="code">plm.eco</field>
            <field name="prefix">ECO/%(year)s/</field>
            <field name="padding">4</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="plm_stage_new" model="plm.eco.stage">
            <field name="name">New</field>
            <field name="sequence">10</field>
            <field name="is_start_stage">True</field>
            <field name="is_approval_required">False</field>
            <field name="is_final_stage">False</field>
            <field name="fold">False</field>
            <field name="color">0</field>
            <field name="description">Initial stage for new ECOs. Fill all mandatory fields then click Start Review.</field>
        </record>

        <record id="plm_stage_in_progress" model="plm.eco.stage">
            <field name="name">In Progress</field>
            <field name="sequence">20</field>
            <field name="is_start_stage">False</field>
            <field name="is_approval_required">False</field>
            <field name="is_final_stage">False</field>
            <field name="fold">False</field>
            <field name="color">3</field>
            <field name="description">ECO is actively being worked on by the Engineering team.</field>
        </record>

        <record id="plm_stage_approval" model="plm.eco.stage">
            <field name="name">Approval</field>
            <field name="sequence">30</field>
            <field name="is_start_stage">False</field>
            <field name="is_approval_required">True</field>
            <field name="is_final_stage">False</field>
            <field name="fold">False</field>
            <field name="color">2</field>
            <field name="description">ECO awaits Approver sign-off. The Approve button is shown; Validate is hidden until approved.</field>
        </record>

        <record id="plm_stage_done" model="plm.eco.stage">
            <field name="name">Done</field>
            <field name="sequence">40</field>
            <field name="is_start_stage">False</field>
            <field name="is_approval_required">False</field>
            <field name="is_final_stage">True</field>
            <field name="fold">True</field>
            <field name="color">10</field>
            <field name="description">ECO applied. New version is active; old version is archived. Changes are live.</field>
        </record>

    </data>
</odoo>
