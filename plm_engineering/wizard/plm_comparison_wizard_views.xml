<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_plm_comparison_wizard_form" model="ir.ui.view">
        <field name="name">plm.comparison.wizard.form</field>
        <field name="model">plm.comparison.wizard</field>
        <field name="arch" type="xml">
            <form string="ECO Change Comparison">
                <sheet>
                    <!-- Summary row -->
                    <group col="4" class="mb-3">
                        <field name="eco_reference"    string="ECO Ref"    readonly="1"/>
                        <field name="eco_name"         string="ECO"        readonly="1"/>
                        <field name="current_version"  string="From"       readonly="1"/>
                        <field name="new_version_label" string="To"        readonly="1"/>
                    </group>
                    <!-- Comparison HTML (generated dynamically from Python) -->
                    <div class="plm-comparison-body">
                        <field name="comparison_html" widget="html"
                               nolabel="1" readonly="1" sanitize="0"/>
                    </div>
                </sheet>
                <footer>
                    <button string="Close" class="btn-primary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_plm_comparison_wizard" model="ir.actions.act_window">
        <field name="name">Change Comparison</field>
        <field name="res_model">plm.comparison.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_eco_id': active_id}</field>
    </record>

</odoo>
